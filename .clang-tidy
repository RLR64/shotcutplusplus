# .clang-tidy
# Place this file at the root of your project.
#
# Strategy: opt into specific useful categories only.
# Excluded project/platform-specific prefixes:
#   llvm, llvmlibc, google, android, apple, darwin, objc,
#   fuchsia, zircon, altera, mpi, openmp, linuxkernel, abseil, boost
#
# Run check-only:   clang-tidy src/main.cpp
# Run with fixes:   clang-tidy --fix src/main.cpp
Checks: >
  -*,
  bugprone-*,
  cppcoreguidelines-*,
  misc-*,
  modernize-*,
  performance-*,
  readability-*
  -fix

# Treat all enabled checks as warnings (not errors).
# Change to true once the codebase is clean to enforce on CI.
WarningsAsErrors: false

# Apply fixes with clang-format style from your .clang-format file.
FormatStyle: file

# Naming conventions - CamelCase for functions and methods,
# m_ prefix for private member variables (Qt convention)
CheckOptions:
  - key: modernize-use-auto.MinTypeNameLength
    value: 5
  - key: misc-unused-parameters.StrictMode
    value: false
